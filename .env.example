# E-Evolve local environment template.
# Copy this file to .env for local runs. Keep .env private.
#
# Online runs use GitHub Actions repository secrets with the same names:
# Settings -> Secrets and variables -> Actions -> New repository secret

# Required for LLM-backed local runs: set at least one.
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Optional local-only LLM provider. Leave blank when using Codex/API keys.
# Set to 1 only if the Anthropic Claude CLI is installed and authenticated.
CLAUDE_CLI_MODE=

# Optional GitHub metadata for local command/secret readiness checks.
# GH_TOKEN can also be named GITHUB_TOKEN locally.
GITHUB_REPO=
GH_TOKEN=
GITHUB_TOKEN=
# Optional: comma/space/newline-separated GitHub Actions secret names for
# readiness checks when a token cannot query repository secret metadata.
GITHUB_CONFIGURED_SECRETS=

# Optional frontend controls.
# Local dev shows offline agent tools by default. Production builds hide them
# unless this is explicitly set to 1.
VITE_ENABLE_OFFLINE_AGENT_UI=

# Optional research controls.
# Set to 0 to disable the default code-tech opportunity research flow.
CODE_TECH_EARN_ENABLED=

# Optional call-to-action text used by legacy draft/social content helpers.
EARN_CTA_URL=
EARN_CTA_LABEL=

# Optional wallet/status context. Used for read-only balance/status checks.
USDT_WALLET_ADDRESS=
ETHERSCAN_API_KEY=

# Legacy action-module credentials.
# Current policy treats these as setup/suggestion context only; the bot must not
# publish, post, trade, withdraw, mint, or comment externally from these keys.
DEV_TO_API_KEY=
MEDIUM_INTEGRATION_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_WITHDRAW_ADDRESS=
ETH_PRIVATE_KEY=
ETH_WALLET_ADDRESS=
NFT_CONTRACT_ADDRESS=
NFT_STORAGE_TOKEN=
